# THLA MES Backend - MẪU biến môi trường (file này commit lên git, KHÔNG để giá trị thật).
# Cách dùng: copy thành .env rồi điền giá trị thật. File .env đã được gitignore.
NODE_ENV=development
PORT=5002

# PostgreSQL
PGHOST=your_db_host
PGPORT=5432
PGDATABASE=your_db_name
PGUSER=your_db_user
PGPASSWORD=your_db_password
PGSSL=false

# JWT — đặt chuỗi ngẫu nhiên đủ dài, BẢO MẬT (đừng commit giá trị thật).
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES=365d

# CORS (frontend origin)
CORS_ORIGIN=https://your-frontend-domain

# ERP — URL API lấy phiếu nhận vải (PHẢI là URL đầy đủ kèm path; code chỉ nối thêm ?fromDate=).
# Mỗi môi trường giữ .env riêng (file .env đã gitignore) nên upload code KHÔNG ghi đè:
#   - LOCAL / trong mạng LAN  : http://10.84.40.34:5000/api/server/backup/mes/phieu-nhan-vai-60
#   - SERVER public           : http://118.69.134.179:5000/api/server/backup/mes/phieu-nhan-vai-60
ERP_PHIEU_NHAN_VAI_URL=http://<erp-host>:5000/api/server/backup/mes/phieu-nhan-vai-60

# (Tùy chọn) ERP nâng cao:
# Job tự đồng bộ ERP mỗi giờ: đặt =false ở LOCAL để KHÔNG chạy khi npm; =true (hoặc bỏ trống, mặc định true) ở SERVER.
ERP_SYNC_ENABLED=false           # LOCAL: false · SERVER (.env riêng): true
# ERP_SYNC_INTERVAL_MIN=5          # chu kỳ (phút) — mặc định 5 phút/lần
# ERP_SYNC_TIMEOUT_MS=600000       # timeout chờ ERP (ms)
# ERP_PROXY_URL=http://host:port   # chỉ định proxy nếu cần ra mạng nội bộ (thường KHÔNG cần)

# (Tùy chọn) Upload/avatar:
# UPLOAD_ROOT=D:/uploads
# PUBLIC_BASE_URL=https://api.thuanhunglongan.com
